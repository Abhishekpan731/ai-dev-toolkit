# MCP Environment Configuration Template
# @author Abhishek Pandey
# @date 2026-05-04
# Copy to ~/.ai-config/env.mcp and fill in your API keys

# ============================================================
# FREE TIER (No API keys required - Always Active)
# ============================================================

# Ollama (Local LLMs)
export OLLAMA_HOST="http://localhost:11434"

# Vector Databases (Local)
export CHROMA_HOST="localhost"
export CHROMA_PORT="8000"
export QDRANT_URL="http://localhost:6333"
export WEAVIATE_URL="http://localhost:8080"

# Local Databases
export SQLITE_DB_PATH="./.data/local.db"
export POSTGRES_USER="postgres"
export POSTGRES_PASSWORD="postgres"
export POSTGRES_HOST="localhost"
export POSTGRES_PORT="5432"
export POSTGRES_DB="postgres"

# ============================================================
# HYBRID TIER (Optional - Enable selective services)
# ============================================================

# AI/ML APIs
export OPENAI_API_KEY=""                    # GPT-4o, embeddings ($30-50/month)
export ANTHROPIC_API_KEY=""                 # Claude 3.5 Sonnet ($20-40/month)
export GOOGLE_API_KEY=""                    # Gemini 2.0 (FREE tier available)
export HUGGINGFACE_API_KEY=""               # HuggingFace Inference API

# Version Control
export GITHUB_TOKEN=""                      # GitHub API access (repos, PRs, issues)

# Cloud Platforms
export AZURE_SUBSCRIPTION_ID=""
export AZURE_TENANT_ID=""
export AZURE_CLIENT_ID=""
export AZURE_CLIENT_SECRET=""

export AWS_REGION="us-east-1"
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# ============================================================
# ENTERPRISE TIER (Optional - Full capabilities)
# ============================================================

# Vector Databases (Managed)
export PINECONE_API_KEY=""
export PINECONE_ENVIRONMENT="us-west1-gcp"

# Monitoring & Observability
export DATADOG_API_KEY=""
export DATADOG_APP_KEY=""
export NEWRELIC_API_KEY=""
export SENTRY_AUTH_TOKEN=""
export SENTRY_ORG=""

# Communication & Collaboration
export SLACK_BOT_TOKEN=""
export SLACK_TEAM_ID=""
export JIRA_URL=""
export JIRA_EMAIL=""
export JIRA_API_TOKEN=""
export NOTION_API_KEY=""

# Additional Cloud Services
export CLOUDFLARE_API_TOKEN=""
export VERCEL_TOKEN=""
export NETLIFY_TOKEN=""
export RAILWAY_TOKEN=""

# ============================================================
# USAGE INSTRUCTIONS
# ============================================================
# 1. Copy this file: cp .ai-config/configs/env.mcp.template ~/.ai-config/env.mcp
# 2. Edit ~/.ai-config/env.mcp and fill in your API keys
# 3. Source in your shell: echo 'source ~/.ai-config/env.mcp' >> ~/.zshrc
# 4. Restart terminal or: source ~/.ai-config/env.mcp
