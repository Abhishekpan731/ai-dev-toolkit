# ============================================================================
# DEVOPS FUNCTIONS: KUBERNETES HELPERS
# ============================================================================

# Switch namespace quickly
knsw() {
    if [ -z "$1" ]; then
        echo "Usage: knsw <namespace>"
        return 1
    fi
    kubectl config set-context --current --namespace=$1
    echo "Switched to namespace: $1"
}

# Get pod by partial name and exec into it
kexec() {
    if [ -z "$1" ]; then
        echo "Usage: kexec <pod-pattern> [command]"
        return 1
    fi
    local pod=$(kubectl get pods | grep $1 | head -1 | awk '{print $1}')
    if [ -z "$pod" ]; then
        echo "No pod found matching: $1"
        return 1
    fi
    local cmd=${2:-/bin/sh}
    echo "Executing into pod: $pod"
    kubectl exec -it $pod -- $cmd
}

# Get logs from pod by partial name
klogs() {
    if [ -z "$1" ]; then
        echo "Usage: klogs <pod-pattern> [-f]"
        return 1
    fi
    local pod=$(kubectl get pods | grep $1 | head -1 | awk '{print $1}')
    if [ -z "$pod" ]; then
        echo "No pod found matching: $1"
        return 1
    fi
    echo "Getting logs from pod: $pod"
    kubectl logs $2 $pod
}

# Delete pod by partial name
kdelpod() {
    if [ -z "$1" ]; then
        echo "Usage: kdelpod <pod-pattern>"
        return 1
    fi
    local pod=$(kubectl get pods | grep $1 | head -1 | awk '{print $1}')
    if [ -z "$pod" ]; then
        echo "No pod found matching: $1"
        return 1
    fi
    echo "Deleting pod: $pod"
    kubectl delete pod $pod
}

# Port forward to pod by partial name
kpfw() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: kpfw <pod-pattern> <local-port:remote-port>"
        return 1
    fi
    local pod=$(kubectl get pods | grep $1 | head -1 | awk '{print $1}')
    if [ -z "$pod" ]; then
        echo "No pod found matching: $1"
        return 1
    fi
    echo "Port forwarding to pod: $pod ($2)"
    kubectl port-forward $pod $2
}

# Get all resources in current namespace
kgetall() {
    echo "=== PODS ==="
    kubectl get pods
    echo "\n=== SERVICES ==="
    kubectl get svc
    echo "\n=== DEPLOYMENTS ==="
    kubectl get deployments
    echo "\n=== CONFIGMAPS ==="
    kubectl get cm
    echo "\n=== SECRETS ==="
    kubectl get secrets
}

