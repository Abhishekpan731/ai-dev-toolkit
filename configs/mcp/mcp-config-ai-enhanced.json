        "TRITON_URL": "${TRITON_URL:-localhost:8000}"
      },
      "description": "NVIDIA Triton Inference Server (OPERATIONAL)",
      "alwaysAllow": ["model_infer", "model_metadata", "server_metadata"]
    },

    "vllm": {
      "command": "npx",
      "args": ["-y", "mcp-vllm-server"],
      "env": {
        "VLLM_HOST": "${VLLM_HOST:-localhost}",
