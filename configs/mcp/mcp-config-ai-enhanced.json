      },
      "description": "Flowise - visual LLM flow builder (OPERATIONAL)",
      "alwaysAllow": ["create_flow", "execute_flow", "get_prediction"]
    },

    "langflow": {
      "command": "npx",
      "args": ["-y", "mcp-langflow-server"],
