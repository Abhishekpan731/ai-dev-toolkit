    "litellm": {
      "command": "npx",
      "args": ["-y", "mcp-litellm-server"],
      "description": "LiteLLM - unified LLM API (100+ models, one interface) (OPERATIONAL)",
      "alwaysAllow": ["completion", "embedding", "image_generation"]
    },

