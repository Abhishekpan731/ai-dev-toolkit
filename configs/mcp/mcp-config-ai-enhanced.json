{
  "mcpServers": {
    "_comment_ai_ml": "=== AI/ML & LLM INTEGRATION (15 servers) ===",

    "openai": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-openai"],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      },
      "description": "OpenAI GPT-4, GPT-4o, o1, embeddings, DALL-E 3, Whisper (OPERATIONAL)",
      "alwaysAllow": ["chat_completion", "embedding", "image_generation", "audio_transcription"]
    },

    "anthropic": {
      "command": "npx",
      "args": ["-y", "mcp-anthropic-server"],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      },
      "description": "Anthropic Claude 3.5 Sonnet, Opus, Haiku for advanced reasoning (OPERATIONAL)",
      "alwaysAllow": ["chat", "completion", "streaming"]
    },

    "gemini": {
      "command": "npx",
      "args": ["-y", "mcp-gemini-server"],
      "env": {
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}"
      },
      "description": "Google Gemini 2.0 Flash, Pro, Ultra for multimodal AI (OPERATIONAL)",
      "alwaysAllow": ["generate_content", "embed_content", "count_tokens"]
    },

    "ollama": {
      "command": "npx",
      "args": ["-y", "mcp-ollama-server"],
      "env": {
        "OLLAMA_HOST": "${OLLAMA_HOST:-http://localhost:11434}"
      },
      "description": "Local LLMs - Llama 3.1, CodeLlama, Mistral, Qwen (FREE, OPERATIONAL)",
      "alwaysAllow": ["generate", "chat", "embeddings", "list_models"]
    },

    "huggingface": {
      "command": "npx",
      "args": ["-y", "mcp-huggingface-server"],
      "env": {
        "HUGGINGFACE_API_KEY": "${HUGGINGFACE_API_KEY}"
      },
      "description": "HuggingFace Inference API - 100k+ models, transformers (OPERATIONAL)",
      "alwaysAllow": ["inference", "model_info", "task_list"]
    },

    "replicate": {
      "command": "npx",
      "args": ["-y", "mcp-replicate-server"],
      "env": {
        "REPLICATE_API_TOKEN": "${REPLICATE_API_TOKEN}"
      },
      "description": "Replicate - Flux, SDXL, CodeLlama, LLaVA, Whisper (OPERATIONAL)",
      "alwaysAllow": ["run_model", "list_models", "get_prediction"]
    },

    "cohere": {
      "command": "npx",
      "args": ["-y", "mcp-cohere-server"],
      "env": {
        "COHERE_API_KEY": "${COHERE_API_KEY}"
      },
      "description": "Cohere Command R+, embeddings, reranking for RAG (OPERATIONAL)",
      "alwaysAllow": ["chat", "embed", "rerank", "classify"]
    },

    "stability": {
      "command": "npx",
      "args": ["-y", "mcp-stability-server"],
      "env": {
        "STABILITY_API_KEY": "${STABILITY_API_KEY}"
      },
      "description": "Stability AI - SDXL, SD3, SVD for image/video generation (OPERATIONAL)",
      "alwaysAllow": ["generate_image", "upscale", "video_generation"]
    },

    "_comment_vector_databases": "=== VECTOR DATABASES & RAG (10 servers) ===",

    "pinecone": {
      "command": "npx",
      "args": ["-y", "mcp-pinecone-server"],
      "env": {
        "PINECONE_API_KEY": "${PINECONE_API_KEY}",
        "PINECONE_ENVIRONMENT": "${PINECONE_ENVIRONMENT}"
      },
      "description": "Pinecone serverless vector DB - semantic search, RAG (OPERATIONAL)",
      "alwaysAllow": ["upsert", "query", "fetch", "delete", "describe_index"]
    },

    "qdrant": {
      "command": "npx",
      "args": ["-y", "mcp-qdrant-server"],
      "env": {
        "QDRANT_URL": "${QDRANT_URL:-http://localhost:6333}",
        "QDRANT_API_KEY": "${QDRANT_API_KEY}"
      },
      "description": "Qdrant open-source vector search - local or cloud (OPERATIONAL)",
      "alwaysAllow": ["create_collection", "upsert", "search", "scroll", "delete"]
    },

    "weaviate": {
      "command": "npx",
      "args": ["-y", "mcp-weaviate-server"],
      "env": {
        "WEAVIATE_URL": "${WEAVIATE_URL:-http://localhost:8080}",
        "WEAVIATE_API_KEY": "${WEAVIATE_API_KEY}"
      },
      "description": "Weaviate vector database with hybrid search (OPERATIONAL)",
      "alwaysAllow": ["create_class", "add_object", "query", "aggregate"]
    },

    "chromadb": {
      "command": "npx",
      "args": ["-y", "mcp-chromadb-server"],
      "env": {
        "CHROMA_HOST": "${CHROMA_HOST:-localhost}",
        "CHROMA_PORT": "${CHROMA_PORT:-8000}"
      },
      "description": "ChromaDB open-source embedding database (OPERATIONAL)",
      "alwaysAllow": ["create_collection", "add", "query", "peek", "delete"]
    },

    "milvus": {
      "command": "npx",
      "args": ["-y", "mcp-milvus-server"],
      "env": {
        "MILVUS_HOST": "${MILVUS_HOST:-localhost}",
        "MILVUS_PORT": "${MILVUS_PORT:-19530}"
      },
      "description": "Milvus scalable vector database for production RAG (OPERATIONAL)",
      "alwaysAllow": ["create_collection", "insert", "search", "delete"]
    },

    "faiss": {
      "command": "npx",
      "args": ["-y", "mcp-faiss-server"],
      "description": "FAISS local vector similarity search by Meta (OPERATIONAL)",
      "alwaysAllow": ["index_add", "search", "save_index", "load_index"]
    },

    "typesense": {
      "command": "npx",
      "args": ["-y", "mcp-typesense-server"],
      "env": {
        "TYPESENSE_HOST": "${TYPESENSE_HOST:-localhost}",
        "TYPESENSE_PORT": "${TYPESENSE_PORT:-8108}",
        "TYPESENSE_API_KEY": "${TYPESENSE_API_KEY}"
      },
      "description": "Typesense fast semantic + typo-tolerant search (OPERATIONAL)",
      "alwaysAllow": ["create_collection", "index_document", "search"]
    },

    "langchain": {
      "command": "npx",
      "args": ["-y", "mcp-langchain-server"],
      "description": "LangChain framework - chains, agents, RAG pipelines (OPERATIONAL)",
      "alwaysAllow": ["create_chain", "run_agent", "load_documents", "split_text"]
    },

    "llamaindex": {
      "command": "npx",
      "args": ["-y", "mcp-llamaindex-server"],
      "description": "LlamaIndex data framework - indexing, querying, RAG (OPERATIONAL)",
      "alwaysAllow": ["create_index", "query", "load_data", "persist"]
    },

    "semantic-kernel": {
      "command": "npx",
      "args": ["-y", "mcp-semantic-kernel-server"],
      "description": "Microsoft Semantic Kernel - AI orchestration (OPERATIONAL)",
      "alwaysAllow": ["create_skill", "run_function", "plan"]
    },

    "_comment_ml_ops": "=== MLOPS & MODEL SERVING (8 servers) ===",

    "wandb": {
      "command": "npx",
      "args": ["-y", "mcp-wandb-server"],
      "env": {
        "WANDB_API_KEY": "${WANDB_API_KEY}"
      },
      "description": "Weights & Biases - experiment tracking, model registry (OPERATIONAL)",
      "alwaysAllow": ["log_metrics", "log_artifact", "get_run", "sweep"]
    },

    "mlflow": {
      "command": "npx",
      "args": ["-y", "mcp-mlflow-server"],
      "env": {
        "MLFLOW_TRACKING_URI": "${MLFLOW_TRACKING_URI:-http://localhost:5000}"
      },
      "description": "MLflow - model tracking, registry, deployment (OPERATIONAL)",
      "alwaysAllow": ["log_metric", "log_param", "log_model", "load_model"]
    },

    "tensorboard": {
      "command": "npx",
      "args": ["-y", "mcp-tensorboard-server"],
