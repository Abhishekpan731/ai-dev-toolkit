      "command": "npx",
      "args": ["-y", "mcp-asana-server"],
      "env": {
        "ASANA_TOKEN": "${ASANA_TOKEN}"
      },
      "description": "Asana - project management (OPERATIONAL)",
      "alwaysAllow": ["asana_create_task", "asana_list_tasks"]
    },

    "trello": {
      "command": "npx",
      "args": ["-y", "mcp-trello-server"],
      "env": {
        "TRELLO_API_KEY": "${TRELLO_API_KEY}",
        "TRELLO_TOKEN": "${TRELLO_TOKEN}"
      },
      "description": "Trello - boards, cards, lists (OPERATIONAL)",
      "alwaysAllow": ["trello_create_card", "trello_list_boards"]
    },

    "monday": {
      "command": "npx",
      "args": ["-y", "mcp-monday-server"],
      "env": {
        "MONDAY_API_KEY": "${MONDAY_API_KEY}"
      },
      "description": "Monday.com - work management (OPERATIONAL)",
      "alwaysAllow": ["monday_create_item", "monday_query"]
    },

    "airtable": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-airtable"],
      "env": {
        "AIRTABLE_API_KEY": "${AIRTABLE_API_KEY}"
      },
      "description": "Airtable - spreadsheet-database hybrid (OPERATIONAL)",
      "alwaysAllow": ["airtable_list_records", "airtable_create_record"]
    }
  }
}
