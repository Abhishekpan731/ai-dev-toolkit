{
  "mcpServers": {
    "_comment_section_1": "=== MICROSOFT ECOSYSTEM (15 servers) ===",

    "azure-all": {
      "command": "npx",
      "args": ["-y", "@azure/mcp"],
      "env": {
        "AZURE_SUBSCRIPTION_ID": "${AZURE_SUBSCRIPTION_ID}",
        "AZURE_TENANT_ID": "${AZURE_TENANT_ID}",
        "AZURE_CLIENT_ID": "${AZURE_CLIENT_ID}",
        "AZURE_CLIENT_SECRET": "${AZURE_CLIENT_SECRET}"
      },
      "description": "Azure MCP - 43+ Azure services (Functions, AKS, SQL, Storage, Key Vault, etc.) (OPERATIONAL)",
      "alwaysAllow": ["azure_*"]
    },

    "azure-aks": {
      "command": "npx",
      "args": ["-y", "@azure/aks-mcp"],
      "env": {
        "AZURE_SUBSCRIPTION_ID": "${AZURE_SUBSCRIPTION_ID}"
      },
      "description": "Azure Kubernetes Service management (OPERATIONAL)",
      "alwaysAllow": ["aks_cluster_info", "aks_scale", "aks_upgrade"]
    },

    "github-official": {
      "command": "npx",
      "args": ["-y", "@github/github-mcp-server", "--toolsets", "repos,issues,pull_requests,code_security"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub official MCP - repos, PRs, issues, code security (OPERATIONAL)",
      "alwaysAllow": ["github_*"]
    },

    "github-copilot": {
      "command": "npx",
      "args": ["-y", "@github/copilot-mcp-server"],
